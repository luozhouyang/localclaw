{
	"name": "localclaw",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "pnpm run build && vite preview",
		"test": "vitest run",
		"test:unit": "vitest run tests/",
		"test:integration": "vitest run integration_tests/ --config integration_tests/vitest.config.ts",
		"test:e2e": "playwright test e2e/",
		"test:e2e:ui": "playwright test e2e/ --ui",
		"test:e2e:debug": "playwright test e2e/ --debug",
		"test:all": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
		"deploy": "pnpm run build && wrangler deploy",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.48",
